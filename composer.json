{
    "name": "gregorj/to-string",
    "description": "A simple PHP library for turning values into readable strings.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Gregor",
            "email": "gregor-j@users.noreply.github.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "GregorJ\\ToString\\": "src"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\GregorJ\\ToString\\": "tests"
        }
    }
}
